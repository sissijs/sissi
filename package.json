{
  "name": "sindie",
  "version": "0.1.0",
  "description": "Sindie — Small Indieweb Static Site generator. Zero external dependencies, Eleventy-inspired API.",
  "main": "index.js",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "test": "node --test",
    "prepublishOnly": "node --test",
    "dev": "node ./src/cli dev",
    "build": "node ./src/cli build",
    "watch": "node ./src/cli watch"
  },
  "bin": {
    "sindie": "src/cli.js"
  },
  "files": [
    "src/",
    "index.js"
  ],
  "keywords": [
    "static-site-generator",
    "ssg",
    "indieweb",
    "zero-dependencies",
    "eleventy"
  ],
  "author": "Lea Rosema",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/sissijs/sissi.git"
  },
  "homepage": "https://sindie.js.org"
}
